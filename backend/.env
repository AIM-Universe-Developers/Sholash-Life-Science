# ─── Gmail SMTP (for Email OTP) ───────────────────────────
# Use your Gmail address and an App Password (not your normal password)
# How to get App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search "App passwords" → Generate a new one (select "Mail" / "Windows Computer")
#   4. Paste the 16-character password below (no spaces)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ─── Fast2SMS (for SMS OTP) ───────────────────────────────
# Sign up FREE at https://www.fast2sms.com
# After login → go to Dev API → copy your API key
FAST2SMS_API_KEY=your_fast2sms_api_key

# ─── Server Port ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

